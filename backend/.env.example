# StartupGPT Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=10000

# MongoDB Atlas (get free cluster at https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/startupgpt?retryWrites=true&w=majority

# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# CORS — set to your Render frontend URL after deploy
# e.g. https://startupgpt-frontend.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com

# JWT
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d
